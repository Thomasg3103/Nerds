# Copy this file to .env (in this same server/ folder) and fill in your values.
# Never commit .env to git.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Settings > API > Secret keys

# Optional — register at https://dev.pokemontcg.io for a free key (higher rate limits)
POKEMON_TCG_API_KEY=

# Required for Games — register at https://rawg.io/apidocs for a free key
RAWG_API_KEY=

PORT=3001
CLIENT_URL=http://localhost:5173
